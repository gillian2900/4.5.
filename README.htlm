<div class="section-detail" id="section-analyse" data-theme="analyse">
<div class="section-hero"><div class="section-hero-left"><button class="btn-back" onclick="showHome()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m15 18-6-6 6-6"/></svg>Retour</button><h1 style="color:var(--accent-analyse)">Analyse</h1><p>Limites, dérivation, intégration et équations différentielles.</p></div></div>
<div class="section-tabs"><button class="section-tab active" onclick="switchTab(this,'analyse-exercices')">Exercices</button><button class="section-tab" onclick="switchTab(this,'analyse-equadiff')">Éq. différentielles</button><button class="section-tab" onclick="switchTab(this,'analyse-cours')">Cours</button><button class="section-tab" onclick="switchTab(this,'analyse-oral')">Oral</button></div>
<div class="tab-content">
