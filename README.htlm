<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Projet 4 à l'écrit, 5 à l'oral</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script type="text/javascript" src="https://ff.kis.v2.scr.kaspersky-labs.com/FD126C42-EBFA-4E12-B309-BB3FDD723AC1/main.js?attr=PTJ_w8xSyODJdb3ogX5cuy0rRO1xCJsIpKMtXp65BAtzMlvnZn7lpsMcfRo0Z-Hdo-eWYNCm3L9Q5_zh3aXIXQ" charset="UTF-8"></script><style>
:root{--bg-deep:#0a0a0f;--bg-card:#12121a;--bg-surface:#16162a;--text-primary:#f0eef6;--text-secondary:#9d9bb8;--text-muted:#5e5c78;--accent-analyse:#ff6b6b;--accent-analyse-glow:rgba(255,107,107,0.3);--accent-fonction:#4ecdc4;--accent-fonction-glow:rgba(78,205,196,0.3);--accent-proba:#a78bfa;--accent-proba-glow:rgba(167,139,250,0.3);--accent-geo:#fbbf24;--accent-geo-glow:rgba(251,191,36,0.3);--accent-programme:#34d399;--accent-programme-glow:rgba(52,211,153,0.3);--accent-algebre:#f472b6;--accent-algebre-glow:rgba(244,114,182,0.3);--gold:#d4a853;--diff-facile:#34d399;--diff-moyen:#fbbf24;--diff-complique:#f97316;--diff-impossible:#ef4444;--border-subtle:rgba(255,255,255,0.06);--border-active:rgba(255,255,255,0.12);--radius-sm:8px;--radius-md:16px;--radius-lg:24px;--shadow-glow:0 0 60px rgba(167,139,250,0.08);--transition-smooth:cubic-bezier(0.22,1,0.36,1)}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;scrollbar-width:thin;scrollbar-color:var(--text-muted) transparent}
body{font-family:'DM Sans',sans-serif;background:var(--bg-deep);color:var(--text-primary);overflow-x:hidden;line-height:1.7;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--text-muted);border-radius:3px}
.bg-canvas{position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:0;pointer-events:none}
.bg-orb{position:absolute;border-radius:50%;filter:blur(100px);opacity:0.12;animation:orbFloat 20s ease-in-out infinite}
.bg-orb:nth-child(1){width:600px;height:600px;background:var(--accent-analyse);top:-200px;left:-100px}
.bg-orb:nth-child(2){width:500px;height:500px;background:var(--accent-proba);top:40%;right:-150px;animation-delay:-7s}
.bg-orb:nth-child(3){width:450px;height:450px;background:var(--accent-fonction);bottom:-100px;left:30%;animation-delay:-14s}
.bg-orb:nth-child(4){width:350px;height:350px;background:var(--accent-geo);top:20%;left:50%;animation-delay:-4s}
@keyframes orbFloat{0%,100%{transform:translate(0,0) scale(1)}25%{transform:translate(80px,-60px) scale(1.1)}50%{transform:translate(-40px,80px) scale(0.9)}75%{transform:translate(60px,40px) scale(1.05)}}
.bg-grid{position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse at 50% 50%,black 30%,transparent 70%)}
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:0 32px;height:72px;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(20px) saturate(1.4);background:rgba(10,10,15,0.7);border-bottom:1px solid var(--border-subtle);transition:all 0.4s var(--transition-smooth)}
.nav.scrolled{height:60px;background:rgba(10,10,15,0.92)}
.nav-logo{display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer}
.nav-logo-icon{width:36px;height:36px}
.nav-logo-text{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;color:var(--text-primary)}
.nav-logo-text span{color:var(--gold)}
.nav-links{display:flex;gap:2px;list-style:none}
.nav-links a{text-decoration:none;color:var(--text-secondary);font-size:0.82rem;font-weight:500;padding:7px 13px;border-radius:100px;transition:all 0.3s;position:relative}
.nav-links a:hover,.nav-links a.active{color:var(--text-primary);background:rgba(255,255,255,0.06)}
.nav-links a::after{content:'';position:absolute;bottom:2px;left:50%;transform:translateX(-50%) scaleX(0);width:18px;height:2px;border-radius:2px;transition:transform 0.3s}
.nav-links a[data-section="analyse"]::after{background:var(--accent-analyse)}
.nav-links a[data-section="fonction"]::after{background:var(--accent-fonction)}
.nav-links a[data-section="proba"]::after{background:var(--accent-proba)}
.nav-links a[data-section="geo"]::after{background:var(--accent-geo)}
.nav-links a[data-section="programme"]::after{background:var(--accent-programme)}
.nav-links a[data-section="algebre"]::after{background:var(--accent-algebre)}
.nav-links a:hover::after,.nav-links a.active::after{transform:translateX(-50%) scaleX(1)}
.nav-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px}
.nav-burger span{display:block;width:24px;height:2px;background:var(--text-primary);border-radius:2px}
.hero{position:relative;z-index:1;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 24px 100px}
.hero-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 18px 6px 8px;background:rgba(212,168,83,0.08);border:1px solid rgba(212,168,83,0.2);border-radius:100px;font-size:0.82rem;color:var(--gold);font-weight:500;margin-bottom:32px;animation:fadeInUp 0.8s var(--transition-smooth) both;letter-spacing:0.04em;text-transform:uppercase}
.hero-badge-dot{width:8px;height:8px;background:var(--gold);border-radius:50%;animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.8)}}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(2.8rem,7vw,5.5rem);font-weight:900;line-height:1.05;letter-spacing:-0.03em;margin-bottom:12px;animation:fadeInUp 0.8s var(--transition-smooth) 0.1s both}
.hero-title .line{display:block}
.hero-title .accent-4{background:linear-gradient(135deg,var(--accent-analyse),var(--accent-proba));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-title .accent-5{background:linear-gradient(135deg,var(--accent-fonction),var(--accent-geo));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-subtitle{font-size:clamp(1rem,2vw,1.2rem);color:var(--text-secondary);max-width:620px;margin:20px auto 48px;animation:fadeInUp 0.8s var(--transition-smooth) 0.2s both;font-weight:300;line-height:1.8}
.hero-cta{display:flex;gap:16px;animation:fadeInUp 0.8s var(--transition-smooth) 0.3s both}
.btn{display:inline-flex;align-items:center;gap:10px;padding:14px 32px;border-radius:100px;font-size:0.92rem;font-weight:600;text-decoration:none;cursor:pointer;border:none;transition:all 0.4s var(--transition-smooth);font-family:'DM Sans',sans-serif}
.btn-primary{background:linear-gradient(135deg,var(--accent-proba),#8b5cf6);color:white;box-shadow:0 4px 24px rgba(167,139,250,0.3)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 40px rgba(167,139,250,0.4)}
.btn-ghost{background:rgba(255,255,255,0.04);color:var(--text-primary);border:1px solid var(--border-active)}
.btn-ghost:hover{background:rgba(255,255,255,0.08);transform:translateY(-2px)}
.hero-symbols{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:hidden}
.math-symbol{position:absolute;font-family:'JetBrains Mono',monospace;color:var(--text-muted);opacity:0.08;font-size:1.4rem;animation:symbolFloat 25s linear infinite}
@keyframes symbolFloat{0%{transform:translateY(100vh) rotate(0deg);opacity:0}10%{opacity:0.08}90%{opacity:0.08}100%{transform:translateY(-100px) rotate(360deg);opacity:0}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.scroll-indicator{position:fixed;bottom:32px;left:0;right:0;display:flex;flex-direction:column;align-items:center;gap:8px;animation:fadeInUp 0.8s var(--transition-smooth) 0.6s both;z-index:10;pointer-events:none;transition:opacity 0.4s ease}
.scroll-indicator span{font-size:0.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.15em}
.scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--text-muted),transparent);position:relative;overflow:hidden}
.scroll-line::after{content:'';position:absolute;top:-100%;width:100%;height:50%;background:var(--gold);animation:scrollDown 2s ease-in-out infinite}
@keyframes scrollDown{0%{top:-50%}100%{top:150%}}
.section-separator{text-align:center;padding:20px 24px 8px;grid-column:1/-1}
.section-separator h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--text-muted);letter-spacing:0.06em;text-transform:uppercase;position:relative;display:inline-block}
.section-separator h3::before,.section-separator h3::after{content:'';position:absolute;top:50%;width:50px;height:1px;background:var(--border-subtle)}
.section-separator h3::before{right:calc(100% + 14px)}
.section-separator h3::after{left:calc(100% + 14px)}
.sections-overview{position:relative;z-index:1;max-width:1280px;margin:0 auto;padding:40px 24px 120px}
.sections-header{text-align:center;margin-bottom:72px}
.sections-header h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;letter-spacing:-0.02em;margin-bottom:16px}
.sections-header p{color:var(--text-secondary);font-size:1.05rem;font-weight:300}
.section-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.section-cards .section-card-full{grid-column:1/-1}
.section-card{position:relative;background:var(--bg-card);border:1px solid var(--border-subtle);border-radius:var(--radius-lg);padding:44px 36px;cursor:pointer;transition:all 0.5s var(--transition-smooth);overflow:hidden;text-decoration:none;display:block}
.section-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:100%;opacity:0;transition:opacity 0.5s ease}
.section-card[data-theme="analyse"]::before{background:radial-gradient(ellipse at 30% 20%,var(--accent-analyse-glow),transparent 70%)}
.section-card[data-theme="fonction"]::before{background:radial-gradient(ellipse at 70% 20%,var(--accent-fonction-glow),transparent 70%)}
.section-card[data-theme="proba"]::before{background:radial-gradient(ellipse at 30% 80%,var(--accent-proba-glow),transparent 70%)}
.section-card[data-theme="geo"]::before{background:radial-gradient(ellipse at 70% 80%,var(--accent-geo-glow),transparent 70%)}
.section-card[data-theme="programme"]::before{background:radial-gradient(ellipse at 50% 50%,var(--accent-programme-glow),transparent 70%)}
.section-card[data-theme="algebre"]::before{background:radial-gradient(ellipse at 50% 50%,var(--accent-algebre-glow),transparent 70%)}
.section-card:hover::before{opacity:1}
.section-card:hover{transform:translateY(-6px);border-color:var(--border-active);box-shadow:var(--shadow-glow)}
.card-number{font-family:'Playfair Display',serif;font-size:4rem;font-weight:900;line-height:1;opacity:0.06;position:absolute;top:16px;right:24px}
.card-icon{width:52px;height:52px;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;margin-bottom:20px;position:relative;z-index:1}
.section-card[data-theme="analyse"] .card-icon{background:rgba(255,107,107,0.12)}
.section-card[data-theme="fonction"] .card-icon{background:rgba(78,205,196,0.12)}
.section-card[data-theme="proba"] .card-icon{background:rgba(167,139,250,0.12)}
.section-card[data-theme="geo"] .card-icon{background:rgba(251,191,36,0.12)}
.section-card[data-theme="programme"] .card-icon{background:rgba(52,211,153,0.12)}
.section-card[data-theme="algebre"] .card-icon{background:rgba(244,114,182,0.12)}
.card-title{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;margin-bottom:8px;position:relative;z-index:1;color:var(--text-primary)}
.card-desc{color:var(--text-secondary);font-size:0.9rem;line-height:1.7;position:relative;z-index:1;margin-bottom:24px}
.card-tags{display:flex;gap:8px;position:relative;z-index:1;flex-wrap:wrap}
.card-tag{padding:5px 14px;border-radius:100px;font-size:0.74rem;font-weight:500}
.section-card[data-theme="analyse"] .card-tag{background:rgba(255,107,107,0.1);color:var(--accent-analyse)}
.section-card[data-theme="fonction"] .card-tag{background:rgba(78,205,196,0.1);color:var(--accent-fonction)}
.section-card[data-theme="proba"] .card-tag{background:rgba(167,139,250,0.1);color:var(--accent-proba)}
.section-card[data-theme="geo"] .card-tag{background:rgba(251,191,36,0.1);color:var(--accent-geo)}
.section-card[data-theme="programme"] .card-tag{background:rgba(52,211,153,0.1);color:var(--accent-programme)}
.section-card[data-theme="algebre"] .card-tag{background:rgba(244,114,182,0.1);color:var(--accent-algebre)}
.card-arrow{position:absolute;bottom:32px;right:32px;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:1px solid var(--border-subtle);transition:all 0.4s;z-index:1}
.section-card:hover .card-arrow{border-color:var(--border-active);transform:translate(4px,-4px)}
.section-detail{display:none;position:relative;z-index:1;min-height:100vh;padding-top:100px}
.section-detail.active{display:block;animation:fadeIn 0.6s var(--transition-smooth)}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.section-hero{max-width:1280px;margin:0 auto;padding:40px 24px 60px}
.section-hero-left h1{font-family:'Playfair Display',serif;font-size:clamp(2.2rem,5vw,3.8rem);font-weight:900;letter-spacing:-0.03em;line-height:1.1;margin-bottom:16px}
.section-hero-left p{color:var(--text-secondary);font-size:1.05rem;max-width:600px;line-height:1.8;font-weight:300}
.btn-back{display:inline-flex;align-items:center;gap:8px;color:var(--text-secondary);font-size:0.88rem;font-weight:500;margin-bottom:20px;cursor:pointer;border:none;background:none;font-family:'DM Sans',sans-serif;transition:color 0.3s;padding:0;text-decoration:none}
.btn-back:hover{color:var(--text-primary)}
.section-tabs{max-width:1280px;margin:0 auto;padding:0 24px;display:flex;gap:4px;border-bottom:1px solid var(--border-subtle);overflow-x:auto}
.section-tab{padding:14px 24px;font-size:0.88rem;font-weight:500;color:var(--text-muted);cursor:pointer;border:none;background:none;font-family:'DM Sans',sans-serif;position:relative;transition:all 0.3s;white-space:nowrap}
.section-tab:hover{color:var(--text-secondary)}
.section-tab.active{color:var(--text-primary)}
.section-tab::after{content:'';position:absolute;bottom:-1px;left:0;width:100%;height:2px;border-radius:2px 2px 0 0;transform:scaleX(0);transition:transform 0.3s}
.section-tab.active::after{transform:scaleX(1)}
[data-theme="analyse"] .section-tab::after{background:var(--accent-analyse)}
[data-theme="fonction"] .section-tab::after{background:var(--accent-fonction)}
[data-theme="proba"] .section-tab::after{background:var(--accent-proba)}
[data-theme="geo"] .section-tab::after{background:var(--accent-geo)}
[data-theme="programme"] .section-tab::after{background:var(--accent-programme)}
[data-theme="algebre"] .section-tab::after{background:var(--accent-algebre)}
.tab-content{max-width:1280px;margin:0 auto;padding:48px 24px 120px}
.tab-pane{display:none;animation:fadeIn 0.4s ease}
.tab-pane.active{display:block}
.content-block{background:var(--bg-card);border:1px solid var(--border-subtle);border-radius:var(--radius-lg);padding:36px;margin-bottom:24px;transition:all 0.3s}
.content-block:hover{border-color:var(--border-active)}
.content-block-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
.content-block-title{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700}
.content-block-badge{padding:4px 14px;border-radius:100px;font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em}
.badge-exercice{background:rgba(255,107,107,0.1);color:var(--accent-analyse)}
.badge-oral{background:rgba(167,139,250,0.1);color:var(--accent-proba)}
.badge-programme{background:rgba(52,211,153,0.1);color:var(--accent-programme)}
.badge-cours{background:rgba(212,168,83,0.1);color:var(--gold)}
.user-content{color:var(--text-secondary);font-size:0.95rem;line-height:1.9}
.user-content h3{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:700;color:var(--text-primary);margin:24px 0 10px}
.user-content p{margin-bottom:14px}
.pdf-embed{margin:20px 0;border-radius:var(--radius-md);overflow:hidden;border:1px solid var(--border-subtle)}
.pdf-embed iframe{border:none;display:block;min-height:500px;width:100%;background:white}
.pdf-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;margin:16px 0}
.pdf-link{display:flex;align-items:center;gap:14px;padding:16px 20px;background:rgba(255,255,255,0.03);border:1px solid var(--border-subtle);border-radius:var(--radius-md);color:var(--text-primary);text-decoration:none;font-size:0.88rem;font-weight:500;transition:all 0.3s}
.pdf-link:hover{background:rgba(255,255,255,0.07);border-color:var(--border-active);transform:translateY(-2px)}
.pdf-link-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(167,139,250,0.08)}
.pdf-link-info{flex:1;min-width:0}
.pdf-link-name{display:block;font-weight:600;color:var(--text-primary);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pdf-link-size{font-size:0.76rem;color:var(--text-muted)}
.pdf-svg{width:20px;height:20px}
.difficulty-section{margin-bottom:40px}
.difficulty-header{display:flex;align-items:center;gap:14px;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border-subtle)}
.difficulty-dot{width:14px;height:14px;border-radius:50%;flex-shrink:0}
.difficulty-dot.facile{background:var(--diff-facile);box-shadow:0 0 12px rgba(52,211,153,0.4)}
.difficulty-dot.moyen{background:var(--diff-moyen);box-shadow:0 0 12px rgba(251,191,36,0.4)}
.difficulty-dot.complique{background:var(--diff-complique);box-shadow:0 0 12px rgba(249,115,22,0.4)}
.difficulty-dot.impossible{background:var(--diff-impossible);box-shadow:0 0 12px rgba(239,68,68,0.4)}
.difficulty-label{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:700}
.difficulty-label.facile{color:var(--diff-facile)}.difficulty-label.moyen{color:var(--diff-moyen)}.difficulty-label.complique{color:var(--diff-complique)}.difficulty-label.impossible{color:var(--diff-impossible)}
.difficulty-count{font-size:0.78rem;color:var(--text-muted);margin-left:auto}
.exo-card{background:var(--bg-card);border:1px solid var(--border-subtle);border-radius:var(--radius-lg);margin-bottom:20px;overflow:hidden;transition:all 0.3s}
.exo-card:hover{border-color:var(--border-active)}
.exo-card.facile{border-left:3px solid var(--diff-facile)}.exo-card.moyen{border-left:3px solid var(--diff-moyen)}.exo-card.complique{border-left:3px solid var(--diff-complique)}.exo-card.impossible{border-left:3px solid var(--diff-impossible)}
.exo-card-header{padding:24px 28px;display:flex;align-items:center;gap:14px}
.exo-card-header h4{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;flex:1}
.exo-number{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:0.78rem;font-weight:700;flex-shrink:0}
.exo-number.facile{background:rgba(52,211,153,0.12);color:var(--diff-facile)}.exo-number.moyen{background:rgba(251,191,36,0.12);color:var(--diff-moyen)}.exo-number.complique{background:rgba(249,115,22,0.12);color:var(--diff-complique)}.exo-number.impossible{background:rgba(239,68,68,0.12);color:var(--diff-impossible)}
.exo-card-body{padding:0 28px 24px}
.hint-stages{padding:0}
.hint-stage{border-top:1px solid var(--border-subtle);padding:14px 0}
.hint-btn{display:inline-flex;align-items:center;gap:10px;padding:10px 22px;border-radius:100px;font-size:0.85rem;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:all 0.4s}
.hint-btn-1{background:linear-gradient(135deg,rgba(251,191,36,0.15),rgba(251,191,36,0.05));color:var(--accent-geo);border:1px solid rgba(251,191,36,0.25)}
.hint-btn-2{background:linear-gradient(135deg,rgba(255,107,107,0.15),rgba(255,107,107,0.05));color:var(--accent-analyse);border:1px solid rgba(255,107,107,0.25);display:none}
.hint-btn-3{background:linear-gradient(135deg,rgba(167,139,250,0.15),rgba(167,139,250,0.05));color:var(--accent-proba);border:1px solid rgba(167,139,250,0.25);display:none}
.hint-btn-solution{background:linear-gradient(135deg,rgba(78,205,196,0.15),rgba(78,205,196,0.05));color:var(--accent-fonction);border:1px solid rgba(78,205,196,0.25);display:none}
.hint-btn:hover{transform:translateY(-1px)}
.hint-content{display:none;margin-top:12px;padding:16px 20px;background:rgba(255,255,255,0.02);border-radius:var(--radius-sm);border-left:3px solid var(--border-subtle);color:var(--text-secondary);line-height:1.8}
.hint-content.visible{display:block;animation:fadeIn 0.4s ease}
.hint-stage[data-type="hint1"] .hint-content{border-left-color:var(--accent-geo)}
.hint-stage[data-type="hint2"] .hint-content{border-left-color:var(--accent-analyse)}
.hint-stage[data-type="hint3"] .hint-content{border-left-color:var(--accent-proba)}
.hint-stage[data-type="solution"] .hint-content{border-left-color:var(--accent-fonction)}
.oral-person-tabs{display:flex;gap:8px;margin-bottom:24px;flex-wrap:wrap}
.oral-person-tab{padding:10px 20px;border-radius:100px;font-size:0.85rem;font-weight:600;cursor:pointer;border:1px solid var(--border-subtle);background:transparent;color:var(--text-muted);font-family:'DM Sans',sans-serif;transition:all 0.3s}
.oral-person-tab:hover{border-color:var(--border-active);color:var(--text-secondary)}
.oral-person-tab.active{background:rgba(167,139,250,0.12);border-color:rgba(167,139,250,0.3);color:var(--accent-proba)}
.oral-person-pane{display:none}.oral-person-pane.active{display:block;animation:fadeIn 0.4s ease}
.schedule-table-wrapper{overflow-x:auto;margin:20px 0;border-radius:var(--radius-md);border:1px solid var(--border-subtle)}
.schedule-table{width:100%;border-collapse:collapse;min-width:600px}
.schedule-table thead th{padding:16px 18px;font-family:'Playfair Display',serif;font-size:0.92rem;font-weight:700;text-align:left;background:rgba(52,211,153,0.06);border-bottom:2px solid rgba(52,211,153,0.2);color:var(--text-primary)}
.schedule-table thead th:first-child{border-right:1px solid var(--border-subtle);width:100px;text-align:center;color:var(--accent-programme)}
.schedule-table tbody td{padding:14px 18px;border-bottom:1px solid var(--border-subtle);border-right:1px solid var(--border-subtle);color:var(--text-secondary);font-size:0.88rem;vertical-align:top}
.schedule-table tbody td:first-child{font-weight:700;color:var(--accent-programme);text-align:center;background:rgba(52,211,153,0.03);font-size:0.8rem;text-transform:uppercase;letter-spacing:0.06em}
.schedule-table tbody td:last-child{border-right:none}
.schedule-table tbody tr:last-child td{border-bottom:none}
.schedule-table tbody tr:hover td{background:rgba(255,255,255,0.02)}
.content-placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 24px;border:2px dashed var(--border-subtle);border-radius:var(--radius-md);text-align:center;color:var(--text-muted)}
.content-placeholder svg{width:40px;height:40px;margin-bottom:12px;opacity:0.4}
.content-placeholder p{font-size:0.85rem}
.footer{position:relative;z-index:1;border-top:1px solid var(--border-subtle);padding:48px 24px;text-align:center}
.footer p{color:var(--text-muted);font-size:0.82rem}
.footer .footer-brand{font-family:'Playfair Display',serif;font-weight:700;color:var(--text-secondary)}
@media(max-width:900px){.section-cards{grid-template-columns:1fr}.section-cards .section-card-full{grid-column:1}.content-block{padding:24px 18px}.pdf-grid{grid-template-columns:1fr}.section-hero-left h1{font-size:2rem}.section-tabs{gap:0}.section-tab{padding:12px 16px;font-size:0.82rem}}
@media(max-width:700px){.nav{padding:0 16px}.nav-links{display:none;position:absolute;top:72px;left:0;right:0;background:rgba(10,10,15,0.96);backdrop-filter:blur(20px);flex-direction:column;padding:16px;border-bottom:1px solid var(--border-subtle)}.nav-links.open{display:flex}.nav-burger{display:flex}.hero-cta{flex-direction:column;width:100%;padding:0 16px}.hero-cta .btn{width:100%;justify-content:center}.hero-title{font-size:2.4rem}.hero-subtitle{font-size:0.95rem;padding:0 8px}.section-card{padding:28px 22px}.card-title{font-size:1.2rem}.card-desc{font-size:0.85rem}.card-number{font-size:2.8rem}.card-arrow{bottom:22px;right:22px}.section-hero{padding:20px 16px 40px}.section-hero-left h1{font-size:1.8rem}.tab-content{padding:24px 16px 80px}.section-tabs{padding:0 16px;gap:0}.section-tab{padding:10px 14px;font-size:0.8rem}.exo-card-header{padding:18px 18px}.exo-card-body{padding:0 18px 18px}.exo-card-header h4{font-size:0.95rem}.hint-btn{padding:8px 16px;font-size:0.8rem}.oral-person-tabs{gap:6px}.oral-person-tab{padding:8px 14px;font-size:0.8rem}.difficulty-header{gap:10px}.difficulty-label{font-size:1rem}.content-block{padding:20px 16px;border-radius:var(--radius-md)}.content-block-title{font-size:1.1rem}.schedule-table{min-width:480px}.schedule-table thead th,.schedule-table tbody td{padding:10px 12px;font-size:0.82rem}.sections-overview{padding:20px 16px 80px}.sections-header h2{font-size:1.6rem}.sections-header{margin-bottom:40px}.scroll-indicator{bottom:20px}}
.reveal{opacity:0;transform:translateY(40px);transition:all 0.8s var(--transition-smooth)}.reveal.visible{opacity:1;transform:translateY(0)}
.stagger>*{opacity:0;transform:translateY(20px);transition:all 0.6s var(--transition-smooth)}
.stagger.visible>*:nth-child(1){transition-delay:0s;opacity:1;transform:none}.stagger.visible>*:nth-child(2){transition-delay:0.06s;opacity:1;transform:none}.stagger.visible>*:nth-child(3){transition-delay:0.12s;opacity:1;transform:none}.stagger.visible>*:nth-child(4){transition-delay:0.18s;opacity:1;transform:none}.stagger.visible>*:nth-child(5){transition-delay:0.24s;opacity:1;transform:none}.stagger.visible>*:nth-child(6){transition-delay:0.3s;opacity:1;transform:none}.stagger.visible>*:nth-child(7){transition-delay:0.36s;opacity:1;transform:none}
.stagger.visible>*:nth-child(8){transition-delay:0.42s;opacity:1;transform:none}
.stagger.visible>*:nth-child(9){transition-delay:0.48s;opacity:1;transform:none}
.stagger.visible>*:nth-child(10){transition-delay:0.54s;opacity:1;transform:none}
.stagger.visible>*:nth-child(n+11){transition-delay:0.6s;opacity:1;transform:none}.stagger.visible>*:nth-child(8){transition-delay:0.42s;opacity:1;transform:none}.stagger.visible>*:nth-child(9){transition-delay:0.48s;opacity:1;transform:none}.stagger.visible>*:nth-child(10){transition-delay:0.54s;opacity:1;transform:none}.stagger.visible>*:nth-child(n+11){transition-delay:0.6s;opacity:1;transform:none}
</style>
</head>
<body>
