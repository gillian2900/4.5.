<div class="tab-pane" id="algebre-cours"><div class="content-block"><div class="content-block-header"><h2 class="content-block-title">Cours — Algèbre linéaire</h2><span class="content-block-badge badge-cours">PDF</span></div><div class="user-content"><div class="pdf-grid"><a href="cours-algebre.pdf" class="pdf-link"><div class="pdf-link-icon"><svg class="pdf-svg" viewBox="0 0 24 24" fill="none" stroke="var(--accent-algebre)" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg></div><div class="pdf-link-info"><span class="pdf-link-name">Cours Algèbre linéaire — à modifier</span><span class="pdf-link-size">PDF</span></div></a></div></div></div></div>
<div class="tab-pane" id="algebre-oral"><div class="content-block"><div class="content-block-header"><h2 class="content-block-title">Oral — Algèbre linéaire</h2><span class="content-block-badge badge-oral">Oral</span></div><div class="user-content"><!-- ✏️ --><div class="pdf-grid"><a href="oral-algebre.pdf" class="pdf-link"><div class="pdf-link-icon"><svg class="pdf-svg" viewBox="0 0 24 24" fill="none" stroke="var(--accent-algebre)" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg></div><div class="pdf-link-info"><span class="pdf-link-name">Oral Algèbre linéaire — à modifier</span><span class="pdf-link-size">PDF</span></div></a></div></div></div></div>
</div></div>

<footer class="footer"><p><span class="footer-brand">Projet 4 à l'écrit, 5 à l'oral</span> — © 2026</p></footer>

<script>
const nav=document.getElementById('nav');const scrollInd=document.querySelector('.scroll-indicator');
window.addEventListener('scroll',()=>{nav.classList.toggle('scrolled',window.scrollY>60);if(scrollInd)scrollInd.style.opacity=window.scrollY>100?'0':'1'});
function toggleMenu(){document.getElementById('navLinks').classList.toggle('open')}
const symbols=['∫','Σ','π','∞','Δ','√','λ','θ','∂','ε','∇','∈','∀','∃','≈','≤','≥','α','β','γ','μ','σ','φ','ω','±','÷','×','∝','⊂','∪','∩','⇒','⇔','≠','ℝ','ℕ','ℤ'];
const container=document.getElementById('mathSymbols');
function createSymbol(){const el=document.createElement('span');el.className='math-symbol';el.textContent=symbols[Math.floor(Math.random()*symbols.length)];el.style.left=Math.random()*100+'%';el.style.animationDuration=(15+Math.random()*20)+'s';el.style.animationDelay=Math.random()*5+'s';el.style.fontSize=(0.9+Math.random()*1.2)+'rem';container.appendChild(el);setTimeout(()=>el.remove(),35000)}
for(let i=0;i<15;i++)setTimeout(createSymbol,i*400);setInterval(createSymbol,2500);
const observer=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')})},{threshold:0.15});
document.querySelectorAll('.reveal,.stagger').forEach(el=>observer.observe(el));
function showHome(){document.getElementById('homePage').style.display='block';document.querySelectorAll('.section-detail').forEach(s=>s.classList.remove('active'));document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));window.scrollTo({top:0,behavior:'smooth'})}
function showSection(name){document.getElementById('homePage').style.display='none';document.querySelectorAll('.section-detail').forEach(s=>s.classList.remove('active'));const t=document.getElementById('section-'+name);if(t){t.classList.add('active');const tabs=t.querySelectorAll('.section-tab'),panes=t.querySelectorAll('.tab-pane');tabs.forEach(t=>t.classList.remove('active'));panes.forEach(p=>p.classList.remove('active'));if(tabs[0])tabs[0].classList.add('active');if(panes[0])panes[0].classList.add('active')}document.querySelectorAll('.nav-links a').forEach(a=>{a.classList.toggle('active',a.dataset.section===name)});window.scrollTo({top:0,behavior:'smooth'});document.getElementById('navLinks').classList.remove('open')}
function switchTab(btn,paneId){const p=btn.closest('.section-detail');p.querySelectorAll('.section-tab').forEach(t=>t.classList.remove('active'));p.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));btn.classList.add('active');document.getElementById(paneId).classList.add('active')}
function revealHint(btn){const stage=btn.closest('.hint-stage'),content=stage.querySelector('.hint-content');content.classList.toggle('visible');if(content.classList.contains('visible')){const next=stage.nextElementSibling;if(next){const nb=next.querySelector('.hint-btn');if(nb){nb.style.display='inline-flex';nb.style.animation='fadeInUp 0.5s ease both'}}btn.style.opacity='0.5';btn.style.pointerEvents='none'}}
function switchOralPerson(btn,paneId){const p=btn.closest('.content-block');p.querySelectorAll('.oral-person-tab').forEach(t=>t.classList.remove('active'));p.querySelectorAll('.oral-person-pane').forEach(p=>p.classList.remove('active'));btn.classList.add('active');document.getElementById(paneId).classList.add('active')}
document.querySelectorAll('.nav-links a').forEach(a=>{const s=a.dataset.section;const c={analyse:'var(--accent-analyse)',fonction:'var(--accent-fonction)',proba:'var(--accent-proba)',geo:'var(--accent-geo)',programme:'var(--accent-programme)',algebre:'var(--accent-algebre)'};a.addEventListener('mouseenter',()=>{a.style.color=c[s]||''});a.addEventListener('mouseleave',()=>{if(!a.classList.contains('active'))a.style.color=''});});
</script>
</body></html>
